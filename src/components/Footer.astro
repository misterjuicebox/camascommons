---
interface Props {
  siteName: string;
  tagline: string;
  contactEmail: string;
}

const { siteName, tagline, contactEmail } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-left">
      <div class="footer-brand">
        <span class="footer-logo">🌿</span>
        <span class="footer-title">{siteName}</span>
      </div>
      <p class="footer-tagline">{tagline}</p>
    </div>

    <div class="footer-right">
      <p class="footer-contact">Questions or inquiries? <a href={`mailto:${contactEmail}`}>{contactEmail}</a></p>
      <div class="footer-meta">
        <span>© {currentYear} {siteName}. Built for community stewardship.</span>
        <a href="/admin" class="admin-link" title="Decap CMS Content Editor">🔐 Admin Portal</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border-glass);
    background: rgba(8, 14, 10, 0.95);
    padding: 3rem 0;
    margin-top: auto;
  }

  .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-logo {
    font-size: 1.4rem;
  }

  .footer-title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-bright);
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .footer-contact {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .footer-contact a {
    color: var(--color-primary-light);
    text-decoration: none;
  }

  .footer-contact a:hover {
    text-decoration: underline;
  }

  .footer-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .admin-link {
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.2rem 0.6rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .admin-link:hover {
    color: var(--color-primary-light);
    background: rgba(16, 185, 129, 0.15);
  }

  @media (max-width: 640px) {
    .footer-container {
      flex-direction: column;
      align-items: flex-start;
    }
    .footer-right {
      align-items: flex-start;
    }
  }
</style>
