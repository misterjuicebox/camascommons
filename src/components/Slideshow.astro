---
// Read images from the public/images/slideshow directory via Vite globbing
const slideshowModules = import.meta.glob('/public/images/slideshow/*');
const allImages = Object.keys(slideshowModules)
  .filter(file => file.endsWith('.jpeg') || file.endsWith('.jpg') || file.endsWith('.png'))
  .map(file => file.replace('/public', ''));

// Limit to 24 curated images to stay well within browser GPU texture width limits (prevents WebKit/Safari animation freeze)
const images = allImages.slice(0, 24);
---

<div class="slideshow-wrapper">
  <div class="slideshow-track">
    {images.map((src, index) => (
      <img src={src} alt={`Slideshow image ${index + 1}`} class="slideshow-img" loading="lazy" />
    ))}
  </div>
  <div class="slideshow-track" aria-hidden="true">
    {images.map((src, index) => (
      <img src={src} alt="" class="slideshow-img" loading="lazy" />
    ))}
  </div>
</div>

<style>
  .slideshow-wrapper {
    display: flex;
    gap: 1.5rem;
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: 2.5rem 0;
    background: var(--color-bg-subtle, #fcfbf9);
    user-select: none;
  }

  /* Fade edges for a smooth vignette look */
  .slideshow-wrapper::before,
  .slideshow-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    width: 10%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .slideshow-wrapper::before {
    left: 0;
    background: linear-gradient(to right, var(--color-bg-paper, #ffffff) 0%, transparent 100%);
  }

  .slideshow-wrapper::after {
    right: 0;
    background: linear-gradient(to left, var(--color-bg-paper, #ffffff) 0%, transparent 100%);
  }

  .slideshow-track {
    display: flex;
    gap: 1.5rem;
    flex-shrink: 0;
    min-width: 100%;
    align-items: center;
    justify-content: space-around;
    animation: marquee 55s linear infinite;
    will-change: transform;
  }

  .slideshow-wrapper:hover .slideshow-track {
    animation-play-state: paused;
  }

  .slideshow-img {
    height: 360px;
    width: auto;
    object-fit: cover;
    border-radius: var(--radius-paper, 12px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.09);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .slideshow-img:hover {
    transform: scale(1.02);
  }

  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-100% - 1.5rem));
    }
  }

  @media (max-width: 768px) {
    .slideshow-img {
      height: 240px;
    }
    .slideshow-track {
      gap: 1rem;
      animation-duration: 45s;
    }
    @keyframes marquee {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(calc(-100% - 1rem));
      }
    }
  }
</style>
