---
interface Props {
  size?: number;
}

const { size = 32 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 40 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class="camas-logo-svg"
  aria-label="Camas Lily Flower Icon"
>
  <!-- Green Stem & Leaf -->
  <path d="M20 38C20 28 20 20 20 18" stroke="#24472F" stroke-width="2.5" stroke-linecap="round"/>
  <path d="M20 30C15 28 11 23 10 18" stroke="#24472F" stroke-width="2" stroke-linecap="round"/>
  <path d="M20 33C25 31 29 26 30 21" stroke="#24472F" stroke-width="2" stroke-linecap="round"/>

  <!-- 6 Petals of Camassia Lily (Star-like layout) -->
  <!-- Top Petal -->
  <path d="M20 18C18.5 12 20 4 20 4C20 4 21.5 12 20 18Z" fill="#7B68EE"/>
  <!-- Top Right Petal -->
  <path d="M20 18C24.5 13.5 32 9 32 9C32 9 27.5 16.5 20 18Z" fill="#6A5ACD"/>
  <!-- Bottom Right Petal -->
  <path d="M20 18C25.5 19.5 33 24 33 24C33 24 25.5 23.5 20 18Z" fill="#7B68EE"/>
  <!-- Bottom Petal -->
  <path d="M20 18C20 24 20 28 20 28C20 28 20 24 20 18Z" fill="#5E4B8B"/>
  <!-- Bottom Left Petal -->
  <path d="M20 18C14.5 23.5 7 24 7 24C7 24 14.5 19.5 20 18Z" fill="#7B68EE"/>
  <!-- Top Left Petal -->
  <path d="M20 18C12.5 16.5 8 9 8 9C8 9 15.5 13.5 20 18Z" fill="#6A5ACD"/>

  <!-- Golden Center Stamens -->
  <circle cx="20" cy="18" r="2.5" fill="#F59E0B"/>
  <circle cx="20" cy="14.5" r="1" fill="#FBBF24"/>
  <circle cx="23" cy="16.5" r="1" fill="#FBBF24"/>
  <circle cx="23" cy="19.5" r="1" fill="#FBBF24"/>
  <circle cx="17" cy="16.5" r="1" fill="#FBBF24"/>
  <circle cx="17" cy="19.5" r="1" fill="#FBBF24"/>
</svg>

<style>
  .camas-logo-svg {
    display: inline-block;
    vertical-align: middle;
    filter: drop-shadow(0 2px 4px rgba(106, 90, 205, 0.25));
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .camas-logo-svg:hover {
    transform: scale(1.1) rotate(5deg);
  }
</style>
