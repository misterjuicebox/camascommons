---
interface Props {
  variant?: 'rose' | 'green' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  id?: string;
  type?: 'button' | 'submit';
  target?: string;
  rel?: string;
  class?: string;
}

const {
  variant = 'rose',
  size = 'md',
  href,
  id,
  type = 'button',
  target,
  rel,
  class: customClass = '',
} = Astro.props;

const Element = href ? 'a' : 'button';
const defaultRel = href && target === '_blank' ? 'noopener noreferrer' : undefined;
---

<Element
  id={id}
  href={href}
  target={target}
  rel={rel || defaultRel}
  type={href ? undefined : type}
  class={`btn btn-${variant} btn-${size} ${customClass}`}
>
  <slot />
</Element>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    border-radius: var(--radius-paper);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid transparent;
    text-align: center;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  /* Sizes */
  .btn-sm {
    padding: 0.45rem 1rem;
    font-size: 0.875rem;
  }

  .btn-md {
    padding: 0.75rem 1.6rem;
    font-size: 0.98rem;
  }

  .btn-lg {
    padding: 1rem 2.2rem;
    font-size: 1.1rem;
  }

  /* Variants */
  .btn-rose {
    background-color: var(--color-rose-terracotta);
    color: #FFFFFF;
    border-color: var(--color-rose-hover);
    box-shadow: 0 2px 8px rgba(197, 116, 109, 0.25);
  }

  .btn-rose:hover {
    background-color: var(--color-rose-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(197, 116, 109, 0.35);
  }

  .btn-green {
    background-color: var(--color-green-deep);
    color: #FFFFFF;
    border-color: var(--color-green-hover);
    box-shadow: 0 2px 8px rgba(36, 71, 47, 0.2);
  }

  .btn-green:hover {
    background-color: var(--color-green-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(36, 71, 47, 0.3);
  }

  .btn-outline {
    background-color: transparent;
    border-color: var(--color-rose-terracotta);
    color: var(--color-rose-terracotta);
  }

  .btn-outline:hover {
    background-color: var(--color-rose-light);
    color: var(--color-rose-hover);
  }

  .btn-ghost {
    background-color: transparent;
    color: var(--color-text-muted);
  }

  .btn-ghost:hover {
    color: var(--color-green-deep);
    background-color: var(--color-green-light);
  }
</style>
