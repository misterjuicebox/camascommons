---
interface Props {
  headline: string;
  paragraphs: string[];
}

const { headline, paragraphs } = Astro.props;
---

<section id="story" class="story-section container">
  <div class="story-grid">
    <div class="story-text-column">
      <span class="section-label">OUR PURPOSE</span>
      <h2 class="story-title">{headline}</h2>
      
      <div class="paragraphs-list">
        {paragraphs.map((p) => (
          <p class="story-p">{p}</p>
        ))}
      </div>
    </div>

    <div class="story-card-column">
      <div class="glass-card vision-card">
        <h3 class="vision-heading">Pillars of Camas Commons</h3>
        <ul class="vision-list">
          <li>
            <span class="vision-icon">🏡</span>
            <div>
              <strong>Community Sanctuary</strong>
              <p>An inclusive space for gatherings, picnics, and neighborhood connection.</p>
            </div>
          </li>
          <li>
            <span class="vision-icon">🌸</span>
            <div>
              <strong>Ecological Stewardship</strong>
              <p>Protecting indigenous flora, fauna, and native pollinators.</p>
            </div>
          </li>
          <li>
            <span class="vision-icon">📚</span>
            <div>
              <strong>Outdoor Learning</strong>
              <p>Hands-on workshops for local youth and nature lovers of all ages.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .story-section {
    padding: 4rem 0;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    align-items: center;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-primary);
  }

  .story-title {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0.4rem 0 1.5rem 0;
  }

  .paragraphs-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .story-p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .vision-card {
    padding: 2rem;
  }

  .vision-heading {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-primary-light);
  }

  .vision-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .vision-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .vision-icon {
    font-size: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    line-height: 1;
  }

  .vision-list strong {
    color: var(--color-text-bright);
    display: block;
    margin-bottom: 0.2rem;
  }

  .vision-list p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 868px) {
    .story-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
