<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Camas Commons Content Admin</title>
    <!-- Explicitly set the CMS config URL so Decap CMS never gets a 404 regardless of trailing slash -->
    <link href="/admin/config.yml" type="text/yaml" rel="cms-config-url" />
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <!-- Netlify / Decap CMS Script -->
    <script is:inline src="https://unpkg.com/netlify-cms@^2.10.192/dist/netlify-cms.js"></script>
    <script is:inline>
      if (window.CMS && window.createReactClass && window.h) {
        var PreviewPlaceholder = window.createReactClass({
          render: function() {
            return window.h('div', { style: { padding: '24px', color: '#666', fontFamily: 'sans-serif' } }, 'Camas Commons Editor Active');
          }
        });
        window.CMS.registerPreviewTemplate("content", PreviewPlaceholder);
        window.CMS.registerPreviewTemplate("fundraiser", PreviewPlaceholder);
        window.CMS.registerPreviewTemplate("faqs", PreviewPlaceholder);
      }
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", (user) => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>
